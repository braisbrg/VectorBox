# TMDB API Configuration
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_READ_TOKEN=your_tmdb_read_token_here

# OMDb API Configuration
OMDB_API_KEY=your_omdb_api_key_here

# Database Configuration
DATABASE_URL=postgresql+asyncpg://vectorbox_user:change_me_in_prod@localhost:5432/vectorbox
POSTGRES_USER=vectorbox_user
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=vectorbox

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Qdrant Configuration
QDRANT_URL=http://localhost:6333

# Default Country for Streaming Providers (ISO 3166-1 alpha-2)
DEFAULT_COUNTRY=

# JWT Secret (generate a secure random string for production)
JWT_SECRET=your-secret-key-change-in-production

# Backend Secret Key (generate a secure random string for production)
SECRET_KEY=your_secret_key_here

# Environment
ENVIRONMENT=development

# Groq API Key
GROQ_API_KEY=your_groq_api_key_here


# --- Hybrid Deployment (Vercel + Cloudflare Tunnel) ---
# Comma-separated list of allowed frontend origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Comma-separated list of trusted hostnames (for TrustedHostMiddleware)
# Include your Cloudflare Tunnel domain here
TRUSTED_HOSTS=localhost,127.0.0.1,your-tunnel-subdomain.trycloudflare.com
