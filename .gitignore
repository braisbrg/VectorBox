# -----------------------------------------------------------------------------
# VECTORBOX PROJECT IGNORE RULES (v1.2 Hardened)
# -----------------------------------------------------------------------------

# System Junk
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.bak
*.swp
*.swo
*~

# IDE/Editor
.vscode/
.idea/
.history/
*.sublime-project
*.sublime-workspace

# Secrets & Environment (CRITICAL)
.env
.env.production
.env.local
.env.*.local
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv/
.pytest_cache/
.coverage
htmlcov/
*.log

# Node.js / Frontend
node_modules/
.next/
out/
build/
dist/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
*.tsbuildinfo

# Docker Persistence (Do not commit production data)
postgres_data/
qdrant_storage/
redis_data/
*.db
*.sqlite

# AI Model Artifacts (Heavy files)
models_cache/
backend/models_cache/
.cache/
*.bin
*.pth
*.safetensors
*.onnx

# Backups & Private Data
backups/
*.snapshot
*.sql
*.sql.gz
*.csv
!backend/fixtures/*.csv
!backend/requirements.lock

# QA & Testing Artifacts
tests/artifacts/
test-results/
*.png
python_procs.txt
backend/tests/fixtures/*.zip

# Playwright
frontend/e2e/reports/
frontend/e2e/test-results/
frontend/e2e/.auth/
frontend/playwright-report/
frontend/test-results/

# Diagnostic temp files
[0-9].txt
*_logs.txt
*_health.txt
*_locks.txt
playwright*.txt
pw_run*.txt
test_output*.txt
phase2-*.txt

# Scripts (Allowlist approach: Ignore temporary debug scripts)
debug_*.py
test_scratch.py
verify_*.py
!backend/scripts/verify_*.py

# AI Agent Configuration & Skills
.agent/
.agents/
.gemini/
skills-lock.json
