{
  "name": "vectorbox-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "security-check": "pnpm audit --audit-level=high",
    "prepare": "cd .. && husky frontend/.husky",
    "audit:backend": "cd .. && python backend/scripts/security_audit.py",
    "audit:container": "docker scout quickview",
    "audit:all": "pnpm audit && npm run audit:backend",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-toast": "1.2.15",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/react-query": "5.90.21",
    "axios": "^1.13.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "12.35.2",
    "lucide-react": "0.577.0",
    "next": "16.1.7",
    "next-themes": "0.4.6",
    "postcss": "^8.5.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "25.4.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3",
      "ajv": ">=8.18.0",
      "flatted": ">=3.4.2",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "yaml": ">=2.8.3"
    }
  }
